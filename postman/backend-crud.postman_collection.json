            "body": {
              "mode": "raw",
              "raw": "{\n  \"company_id\": {{companyId}},\n  \"branch_id\": {{branchId}},\n  \"sku\": \"POSTMAN-SKU-UPDATED\",\n  \"name\": \"Postman Product Updated\",\n  \"description\": \"Producto actualizado desde Postman\",\n  \"category\": \"demo\",\n  \"brand\": \"postman\",\n  \"price_cents\": 18990,\n  \"currency\": \"CLP\",\n  \"stock\": 15\n}"
            },
            "url": "{{baseUrl}}/products/{{productId}}"
