                "key": "Authorization",
                "value": "Bearer {{salesUserToken}}"
              }
            ],
            "url": "{{baseUrl}}/products/{{productId}}/neighbors?limit=5&min_similarity=0.20"
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
