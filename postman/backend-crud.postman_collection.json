              "mode": "raw",
              "raw": "{\n  \"company_id\": {{companyId}},\n  \"branch_id\": {{branchId}},\n  \"sku\": \"POSTMAN-SKU-{{$timestamp}}\",\n  \"name\": \"Postman Product {{$timestamp}}\",\n  \"description\": \"Producto creado desde Postman\",\n  \"category\": \"demo\",\n  \"brand\": \"postman\",\n  \"price_cents\": 15990,\n  \"currency\": \"CLP\",\n  \"stock\": 20\n}"
            },
            "url": "{{baseUrl}}/products"
          }
        },
